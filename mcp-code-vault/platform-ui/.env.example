# Stats server port (must match PORT in the backend .env). Default 3000.
# STATS_PORT=3001

# Listen on all interfaces (e.g. for LAN access). Set to 0.0.0.0 to enable.
# NUXT_HOST=0.0.0.0

# Discovery: remove a registered MCP from the list after this many ms without a new register (default 5000).
# DISCOVERY_STALE_MS=5000
